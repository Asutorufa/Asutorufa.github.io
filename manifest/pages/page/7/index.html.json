yle=\"color:#24292E;--shiki-dark:#E1E4E8\">);</span></span></span><span class=\"code-line\"><span class=\"code-line-content\"><span style=\"color:#6F42C1;--shiki-dark:#B392F0\"> printf</span><span style=\"color:#24292E;--shiki-dark:#E1E4E8\">(</span><span style=\"color:#032F62;--shiki-dark:#9ECBFF\">\"</span><span style=\"color:#005CC5;--shiki-dark:#79B8FF\">%d</span><span style=\"color:#005CC5;--shiki-dark:#79B8FF\"> %d</span><span style=\"color:#005CC5;--shiki-dark:#79B8FF\"> %d</span><span style=\"color:#005CC5;--shiki-dark:#79B8FF\"> \\n</span><span style=\"color:#032F62;--shiki-dark:#9ECBFF\">\"</span><span style=\"color:#24292E;--shiki-dark:#E1E4E8\">,b.a,b.b,b.c);</span></span></span><span class=\"code-line\"><span class=\"code-line-content\"><span style=\"color:#24292E;--shiki-dark:#E1E4E8\"> T </span><span style=\"color:#D73A49;--shiki-dark:#F97583\">*</span><span style=\"color:#24292E;--shiki-dark:#E1E4E8\">f</span><span style=\"color:#D73A49;--shiki-dark:#F97583\">=&#x26;</span><span style=\"color:#24292E;--shiki-dark:#E1E4E8\">b;</span></span></span><span class=\"code-line\"><span class=\"code-line-content\"><span style=\"color:#6F42C1;--shiki-dark:#B392F0\"> printf</span><span style=\"color:#24292E;--shiki-dark:#E1E4E8\">(</span><span style=\"color:#032F62;--shiki-dark:#9ECBFF\">\"</span><span style=\"color:#005CC5;--shiki-dark:#79B8FF\">%d</span><span style=\"color:#005CC5;--shiki-dark:#79B8FF\"> %d</span><span style=\"color:#005CC5;--shiki-dark:#79B8FF\"> %d</span><span style=\"color:#032F62;--shiki-dark:#9ECBFF\">\"</span><span style=\"color:#24292E;--shiki-dark:#E1E4E8\">,f->a,f->b,f->c);</span></span></span><span class=\"code-line\"><span class=\"code-line-content\"><span style=\"color:#24292E;--shiki-dark:#E1E4E8\">}</span></span></span></code></pre>\n<h2 id=\"c\">C++</h2>\n","moreAnchor":"more","bodyMarkdown":"","bodyHtml":"","rawMarkdown":"","plainText":"","toc":[],"slugForSearch":"c69434f1","comments":true,"math":false,"mermaid":false},{"kind":