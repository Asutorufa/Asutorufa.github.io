ass=\"code-line-content\"><span style=\"color:#D73A49;--shiki-dark:#F97583\">bool</span><span style=\"color:#6F42C1;--shiki-dark:#B392F0\"> get_left_eye</span><span style=\"color:#24292E;--shiki-dark:#E1E4E8\">(</span><span style=\"color:#6F42C1;--shiki-dark:#B392F0\">cv</span><span style=\"color:#24292E;--shiki-dark:#E1E4E8\">::</span><span style=\"color:#6F42C1;--shiki-dark:#B392F0\">Mat</span><span style=\"color:#E36209;--shiki-dark:#FFAB70\"> image</span><span style=\"color:#24292E;--shiki-dark:#E1E4E8\">, </span><span style=\"color:#6F42C1;--shiki-dark:#B392F0\">cv</span><span style=\"color:#24292E;--shiki-dark:#E1E4E8\">::</span><span style=\"color:#6F42C1;--shiki-dark:#B392F0\">Mat</span><span style=\"color:#D73A49;--shiki-dark:#F97583\"> &#x26;</span><span style=\"color:#E36209;--shiki-dark:#FFAB70\">out</span><span style=\"color:#24292E;--shiki-dark:#E1E4E8\">)</span></span></span><span class=\"code-line\"><span class=\"code-line-content\"><span style=\"color:#24292E;--shiki-dark:#E1E4E8\">{</span></span></span><span class=\"code-line\"><span class=\"code-line-content\"><span style=\"color:#6A737D;--shiki-dark:#6A737D\">    // 之后与面部相同</span></span></span><span class=\"code-line\"><span class=\"code-line-content\"><span style=\"color:#6F42C1;--shiki-dark:#B392F0\">    cv</span><span style=\"color:#24292E;--shiki-dark:#E1E4E8\">::Mat gray;</span></span></span><span class=\"code-line\"><span class=\"code-line-content\"><span style=\"color:#6F42C1;--shiki-dark:#B392F0\">    cv</span><span style=\"color:#24292E;--shiki-dark:#E1E4E8\">::</span><span style=\"color:#6F42C1;--shiki-dark:#B392F0\">cvtColor</span><span style=\"color:#24292E;--shiki-dark:#E1E4E8\">(image, gray, CV_BGR2GRAY, </span><span style=\"color:#005CC5;--shiki-dark:#79B8FF\">0</span><span style=\"color:#24292E;--shiki-dark:#E1E4E8\">);</span></span></span><span class=\"code-line\"><span class=\"code-line-content\"><span style=\"color:#6F42C1;--shiki-dark:#B392F0\">    std</span><span style=\"colo