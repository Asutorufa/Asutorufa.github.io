{
  "typescript": {},
  "json": {},
  "markdown": {
    "lineWidth": 20,
    "tags": {
      "astro": "astro",
      "bash": "sh",
      "cjs": "js",
      "css": "css",
      "go": "go",
      "htm": "html",
      "html": "html",
      "javascript": "js",
      "js": "js",
      "json": "json",
      "jsonc": "jsonc",
      "jsx": "jsx",
      "less": "less",
      "markdown": "md",
      "md": "md",
      "mjs": "js",
      "mts": "ts",
      "sass": "sass",
      "scss": "scss",
      "sh": "sh",
      "shell": "sh",
      "svelte": "svelte",
      "toml": "toml",
      "ts": "ts",
      "tsx": "tsx",
      "typescript": "ts",
      "vue": "vue",
      "yaml": "yaml",
      "yml": "yaml"
    }
  },
  "toml": {},
  "malva": {},
  "markup": {},
  "yaml": {},
  "exec": {
    "cwd": "${configDir}",
    "commands": [
      {
        "command": "gofumpt",
        "exts": [
          "go"
        ]
      },
      {
        "command": "shfmt -i 2 -ci -sr",
        "exts": [
          "sh",
          "bash"
        ]
      }
    ]
  },
  "excludes": [
    "**/node_modules",
    "**/*-lock.json"
  ],
  "plugins": [
    "https://plugins.dprint.dev/typescript-0.96.1.wasm",
    "https://plugins.dprint.dev/json-0.22.0.wasm",
    "https://plugins.dprint.dev/markdown-0.22.1.wasm",
    "https://plugins.dprint.dev/toml-0.7.0.wasm",
    "https://plugins.dprint.dev/g-plane/malva-v0.16.0.wasm",
    "https://plugins.dprint.dev/g-plane/markup_fmt-v0.27.3.wasm",
    "https://plugins.dprint.dev/g-plane/pretty_yaml-v0.6.0.wasm",
    "https://plugins.dprint.dev/exec-0.7.1.json@8208a6a2f32d1f03162318f92af0182ee7f4e99212497eb15f53599c13783e77"
  ]
}
