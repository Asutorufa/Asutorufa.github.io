{
  "name": "asutorufa-react-blog",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "npm run react:build",
    "build:full": "npm run react:build:full",
    "build:content": "npm run react:build:content",
    "analyze": "ANALYZE=true npm run react:build:full",
    "post:new": "node --import tsx tools/react-blog/new-post.ts",
    "prelint": "npm run react:generate",
    "lint": "eslint src tools/react-blog vite.config.mts",
    "prelint:fix": "npm run react:generate",
    "lint:fix": "eslint src tools/react-blog vite.config.mts --fix",
    "prereact:dev": "npm run react:generate",
    "react:dev": "vite --host 0.0.0.0",
    "react:generate": "node --import tsx tools/react-blog/generate-client-common.ts",
    "react:build": "node --import tsx tools/react-blog/build.ts",
    "react:build:full": "node --import tsx tools/react-blog/build.ts --full",
    "react:build:content": "node --import tsx tools/react-blog/build.ts --content-only",
    "react:preview": "vite preview --outDir dist-react --host 0.0.0.0"
  },
  "dependencies": {
    "@renbaoshuo/markdown-it-katex": "^2.0.2",
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "clsx": "^2.1.1",
    "fast-glob": "^3.3.3",
    "katex": "^0.17.0",
    "lucide-react": "^1.21.0",
    "markdown-it": "^14.1.0",
    "mermaid": "^11.15.0",
    "motion": "^12.40.0",
    "prismjs": "^1.30.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shiki": "^4.2.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.20.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "wouter": "^3.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^26.0.0",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript-eslint": "^8.61.1"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
